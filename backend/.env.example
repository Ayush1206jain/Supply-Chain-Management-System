# Copy to .env and fill in values

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ───────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/supply-chain

# ── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_local_env

# ── Blockchain  ─────────────────────────────────────────────────────
# Local Hardhat node (run: cd blockchain && npm run node)
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545

# Private key of Account #0 printed by `npm run node` (Hardhat default)
# NEVER commit a real private key — this is for local dev only!
DEPLOYER_PRIVATE_KEY= PRIVATE_KEY

# Address printed by `npm run deploy:local` after successful deployment
CONTRACT_ADDRESS=0xYourDeployedContractAddressHere

# ── Blockchain Retry Job  ──────────────────────────────────────────
# How often the background job retries failed chain calls (ms). Default: 60000
CHAIN_SYNC_INTERVAL_MS=60000

# Max number of retry attempts per failed transfer / un-anchored product.
# Records exceeding this cap are marked permanently failed. Default: 5
CHAIN_SYNC_MAX_RETRIES=5

# How many records to process per retry pass. Default: 20
CHAIN_SYNC_BATCH_SIZE=20
